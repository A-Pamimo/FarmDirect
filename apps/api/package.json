{
  "name": "@harvestlink/api",
  "version": "0.0.1",
  "private": true,
  "type": "commonjs",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "lint": "eslint 'src/**/*.{ts,tsx}'",
    "format": "prettier --write 'src/**/*.{ts,tsx,js,json}'",
    "test": "vitest --run",
    "db:migrate": "node scripts/run-sql.js db/migrations",
    "db:seed": "node scripts/run-sql.js db/seeds"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "helmet": "^7.1.0",
    "morgan": "^1.10.0",
    "pg": "^8.11.5",
    "stripe": "^15.5.0",
    "twilio": "^4.22.0",
    "zod": "^3.23.8",
    "nodemailer": "^6.9.13",
    "@harvestlink/shared": "file:../../packages/shared",
    "express-rate-limit": "^7.1.5"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/morgan": "^1.9.7",
    "@types/node": "^20.12.12",
    "@types/nodemailer": "^6.4.12",
    "@types/supertest": "^2.0.16",
    "@types/cors": "^2.8.17",
    "@types/stripe": "^8.0.0",
    "@typescript-eslint/eslint-plugin": "^7.8.0",
    "@typescript-eslint/parser": "^7.8.0",
    "eslint": "^8.57.0",
    "prettier": "^3.2.5",
    "supertest": "^6.3.3",
    "tsx": "^4.7.0",
    "typescript": "^5.4.5",
    "vitest": "^1.5.1"
  }
}
